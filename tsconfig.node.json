{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "out",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "types/**/*.d.ts"]
}
